{
  "name": "codereview-json",
  "displayName": "CodeReview.json",
  "description": "GitHub-style local code review comments, stored as JSON for AI agents.",
  "version": "0.0.2",
  "publisher": "poalrom",
  "license": "MIT",
  "author": "Alex Popkov <poalrom@toloka.ai>",
  "homepage": "https://github.com/poalrom/vscode-local-code-review-extension#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/poalrom/vscode-local-code-review-extension.git"
  },
  "bugs": {
    "url": "https://github.com/poalrom/vscode-local-code-review-extension/issues"
  },
  "keywords": ["code review", "review", "comments", "ai", "agent", "local"],
  "engines": { "vscode": "^1.90.0" },
  "categories": ["Other"],
  "main": "./dist/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      { "command": "review.newReview", "title": "Code Review: New Review", "icon": "$(add)" },
      { "command": "review.switchActive", "title": "Code Review: Switch Active Review" },
      { "command": "review.makeActive", "title": "Make Active" },
      { "command": "review.deleteReview", "title": "Code Review: Delete Review" },
      { "command": "review.addComment", "title": "Code Review: Add Comment" },
      { "command": "review.refresh", "title": "Code Review: Refresh", "icon": "$(refresh)" },
      { "command": "review.replySubmit", "title": "Reply" },
      { "command": "review.resolve", "title": "Resolve", "icon": "$(check)" },
      { "command": "review.reopen", "title": "Reopen", "icon": "$(history)" },
      { "command": "review.editComment", "title": "Edit", "icon": "$(edit)" },
      { "command": "review.editCommentSave", "title": "Save" },
      { "command": "review.editCommentCancel", "title": "Cancel" }
    ],
    "viewsContainers": {
      "activitybar": [
        { "id": "reviewContainer", "title": "Code Review", "icon": "$(comment-discussion)" }
      ]
    },
    "views": {
      "reviewContainer": [
        { "id": "reviewTree", "name": "Reviews" }
      ]
    },
    "menus": {
      "editor/context": [
        { "command": "review.addComment", "when": "editorHasSelection", "group": "navigation@9" }
      ],
      "view/title": [
        { "command": "review.newReview", "when": "view == reviewTree", "group": "navigation" },
        { "command": "review.refresh", "when": "view == reviewTree", "group": "navigation" }
      ],
      "comments/commentThread/context": [
        { "command": "review.replySubmit", "group": "inline" }
      ],
      "comments/commentThread/title": [
        { "command": "review.resolve", "when": "commentThread == open", "group": "navigation" },
        { "command": "review.reopen", "when": "commentThread == resolved", "group": "navigation" }
      ],
      "comments/comment/title": [
        { "command": "review.editComment", "when": "comment == canEdit", "group": "inline@1" }
      ],
      "comments/comment/context": [
        { "command": "review.editCommentSave", "when": "comment == canEdit", "group": "inline@1" },
        { "command": "review.editCommentCancel", "when": "comment == canEdit", "group": "inline@2" }
      ],
      "view/item/context": [
        { "command": "review.makeActive", "when": "view == reviewTree && viewItem == review", "group": "navigation" },
        { "command": "review.resolve", "when": "view == reviewTree && viewItem == thread-open", "group": "navigation" },
        { "command": "review.reopen", "when": "view == reviewTree && viewItem == thread-resolved", "group": "navigation" }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "package": "vsce package",
    "publish": "vsce publish",
    "publish:ovsx": "ovsx publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.21.0",
    "ovsx": "^0.10.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
